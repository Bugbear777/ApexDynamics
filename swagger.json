{
  "openapi": "3.0.0",
  "info": {
    "title": "ApexDynamics API",
    "version": "1.0.0",
    "description": "API for managing ApexDynamics vehicle catalog"
  },
  "servers": [
  {
    "url": "https://apexdynamics.onrender.com",
    "description": "Render server"
  },
  {
    "url": "http://localhost:3000",
    "description": "Local server"
  }
  ],
  "paths": {
    "/": {
      "get": {
        "summary": "Home route",
        "responses": {
          "200": {
            "description": "API running confirmation"
          }
        }
      }
    },
    "/vehicles": {
      "get": {
        "summary": "Get all vehicles",
        "responses": {
          "200": {
            "description": "Returns all vehicles"
          }
        }
      },
      "post": {
        "summary": "Create a new vehicle",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Vehicle"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Vehicle created successfully"
          },
          "400": {
            "description": "Invalid input"
          }
        }
      }
    },
    "/manufacturers": {
      "get": {
        "summary": "Get all manufacturers",
        "responses": {
          "200": {
            "description": "Returns all manufacturers"
          }
        }
      },
      "post": {
        "summary": "Create a new manufacturer",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Manufacturer"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Manufacturer created successfully"
          },
          "400": {
            "description": "Invalid input"
          }
        }
      }
    },
    "/vehicles/{id}": {
      "get": {
        "summary": "Get one vehicle by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "MongoDB ObjectId of the vehicle",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Returns one vehicle"
          },
          "404": {
            "description": "Vehicle not found"
          }
        }
      },
      "put": {
        "summary": "Update a vehicle by ID",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "MongoDB ObjectId of the vehicle",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Vehicle"
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Vehicle updated successfully"
          },
          "400": {
            "description": "Invalid input"
          },
          "404": {
            "description": "Vehicle not found"
          }
        }
      },
      "delete": {
        "summary": "Delete a vehicle by ID",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "MongoDB ObjectId of the vehicle",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Vehicle deleted successfully"
          },
          "404": {
            "description": "Vehicle not found"
          }
        }
      }
    },
    "/manufacturers/{id}": {
      "get": {
        "summary": "Get one manufacturer by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "MongoDB ObjectId of the manufacturer",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Returns one manufacturer"
          },
          "404": {
            "description": "Manufacturer not found"
          }
        }
      },
      "put": {
        "summary": "Update a manufacturer by ID",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "MongoDB ObjectId of the manufacturer",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/Manufacturer"
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "Manufacturer updated successfully"
          },
          "400": {
            "description": "Invalid input"
          },
          "404": {
            "description": "Manufacturer not found"
          }
        }
      },
      "delete": {
        "summary": "Delete a manufacturer by ID",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "description": "MongoDB ObjectId of the manufacturer",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Manufacturer deleted successfully"
          },
          "404": {
            "description": "Manufacturer not found"
          }
        }
      }
    },
    "/auth/register": {
      "post": {
        "summary": "Register a new user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserRegister"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User created successfully"
          },
          "400": {
            "description": "Invalid input or user already exists"
          },
          "500": {
            "description": "Registration failed"
          }
        }
      }
    },
    "/auth/login": {
      "post": {
        "summary": "Log in a user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserLogin"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful"
          },
          "401": {
            "description": "Invalid email or password"
          },
          "500": {
            "description": "Login failed"
          }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "summary": "Log out a user",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Logout successful"
          }
        }
      }
    }
  },
  "components": {
  "schemas": {
    "Vehicle": {
      "type": "object",
      "required": [
        "name",
        "type",
        "price",
        "blockCount",
        "topSpeed",
        "crewSize",
        "mainWeapon",
        "weight"
      ],
      "properties": {
        "name": {
          "type": "string",
          "example": "LTV Pathfinder Recon Vehicle"
        },
        "type": {
          "type": "string",
          "example": "Light Tactical Vehicle"
        },
        "price": {
          "type": "number",
          "example": 4055000
        },
        "blockCount": {
          "type": "integer",
          "example": 55
        },
        "topSpeed": {
          "type": "number",
          "example": 125
        },
        "crewSize": {
          "type": "integer",
          "example": 2
        },
        "mainWeapon": {
          "type": "string",
          "example": "None"
        },
        "weight": {
          "type": "number",
          "example": 183.7
        }
      }
    },
    "Manufacturer": {
      "type": "object",
      "required": [
        "name",
        "country",
        "foundedYear",
        "specialty",
        "ceo",
        "isActive"
      ],
      "properties": {
        "name": {
          "type": "string",
          "example": "Apex Dynamics"
        },
        "country": {
          "type": "string",
          "example": "United States"
        },
        "foundedYear": {
          "type": "integer",
          "example": 2021
        },
        "specialty": {
          "type": "string",
          "example": "Military vehicles"
        },
        "ceo": {
          "type": "string",
          "example": "Joseph Marlow"
        },
        "isActive": {
          "type": "boolean",
          "example": true
        }
      }
    },
    "UserRegister": {
      "type": "object",
      "required": [
        "email",
        "password",
        "firstName",
        "lastName"
      ],
      "properties": {
        "email": {
          "type": "string",
          "example": "joseph@example.com"
        },
        "password": {
          "type": "string",
          "example": "MyPassword123"
        },
        "firstName": {
          "type": "string",
          "example": "Joseph"
        },
        "lastName": {
          "type": "string",
          "example": "Marlow"
        }
      }
    },
    "UserLogin": {
      "type": "object",
      "required": [
        "email",
        "password"
      ],
      "properties": {
        "email": {
          "type": "string",
          "example": "joseph@example.com"
        },
        "password": {
          "type": "string",
          "example": "MyPassword123"
        }
      }
    }
  },
  "securitySchemes": {
    "bearerAuth": {
      "type": "http",
      "scheme": "bearer",
      "bearerFormat": "JWT"
    }
  }
}
}